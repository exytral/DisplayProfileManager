<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base Colors -->
    <Color x:Key="BackgroundColor">#000000</Color>
    <Color x:Key="SurfaceColor">#1D1D1D</Color>
    <Color x:Key="BorderColor">#2A2A2A</Color>
    <Color x:Key="HoverColor">#2A2A2A</Color>
    <Color x:Key="AccentColor">#8AB4F8</Color>

    <!-- Window Backgrounds -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="AlternateBackgroundBrush" Color="{StaticResource BackgroundColor}"/>

    <!-- Content & Control Backgrounds -->
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="TextBoxBackgroundBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="ComboBoxBackgroundBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="ComboBoxDropDownBackgroundBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CheckBoxBackgroundBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="ListItemBackgroundBrush" Color="{StaticResource BackgroundColor}"/>

    <!-- Borders & Separators -->
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="TextBoxBorderBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="CheckBoxBorderBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="WindowControlHoverBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="ListItemSelectedBackgroundBrush" Color="{StaticResource HoverColor}"/>

    <!-- Interaction States -->
    <SolidColorBrush x:Key="ControlHoverBackgroundBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="ListItemHoverBackgroundBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="ComboBoxHoverBackgroundBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="ControlPressedBackgroundBrush" Color="#121212"/>

    <!-- Primary Button (Accent) -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#202124"/>
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#A8C7FA"/>
    <SolidColorBrush x:Key="ButtonPressedBackgroundBrush" Color="#669DF6"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="TextBoxFocusBorderBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="CheckBoxCheckmarkBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="LinkBrush" Color="{StaticResource AccentColor}"/>

    <!-- Secondary Button -->
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SecondaryButtonForegroundBrush" Color="#F1F1F1"/>
    <SolidColorBrush x:Key="SecondaryButtonHoverBackgroundBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="SecondaryButtonPressedBackgroundBrush" Color="#121212"/>
    <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="#3A3A3A"/>

    <!-- Status Buttons -->
    <SolidColorBrush x:Key="DangerButtonBackgroundBrush" Color="#F28B82"/>
    <SolidColorBrush x:Key="DangerButtonHoverBackgroundBrush" Color="#EE675C"/>
    <SolidColorBrush x:Key="SuccessButtonBackgroundBrush" Color="#81C995"/>
    <SolidColorBrush x:Key="SuccessButtonHoverBackgroundBrush" Color="#A8DAB5"/>

    <!-- Title Bar Extras -->
    <SolidColorBrush x:Key="TitleBarTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CloseButtonHoverBrush" Color="#CD212F"/>

    <!-- Text Brushes -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TertiaryTextBrush" Color="#AFAFAF"/>

    <!-- Tooltips -->
    <SolidColorBrush x:Key="TooltipBackgroundBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="TooltipTextBrush" Color="#F5F5F5"/>

    <!-- Effects -->
    <DropShadowEffect x:Key="CardShadow" ShadowDepth="2" Direction="270" BlurRadius="8" Opacity="0.6" Color="#1D1D1D"/>
    <DropShadowEffect x:Key="ButtonShadow" ShadowDepth="1" Direction="270" BlurRadius="4" Opacity="0.4" Color="#1D1D1D"/>

</ResourceDictionary>