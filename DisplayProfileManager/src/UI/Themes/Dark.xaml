<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base Colors -->
    <Color x:Key="BackgroundColor">#1E1E1E</Color>
    <Color x:Key="SurfaceColor">#2D2D30</Color>
    <Color x:Key="BorderColor">#3F3F46</Color>
    <Color x:Key="HoverColor">#4A4A4D</Color>
    <Color x:Key="AccentColor">#0E639C</Color>

    <!-- Window Backgrounds -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="AlternateBackgroundBrush" Color="#252526"/>

    <!-- Content & Control Backgrounds -->
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#3E3E42"/>
    <SolidColorBrush x:Key="TextBoxBackgroundBrush" Color="#3E3E42"/>
    <SolidColorBrush x:Key="ComboBoxBackgroundBrush" Color="#3E3E42"/>
    <SolidColorBrush x:Key="ComboBoxDropDownBackgroundBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="CheckBoxBackgroundBrush" Color="#3E3E42"/>
    <SolidColorBrush x:Key="ListItemBackgroundBrush" Color="{StaticResource SurfaceColor}"/>

    <!-- Borders & Separators -->
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="#464647"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#555555"/>
    <SolidColorBrush x:Key="TextBoxBorderBrush" Color="#555555"/>
    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#555555"/>
    <SolidColorBrush x:Key="CheckBoxBorderBrush" Color="#6E6E6E"/>
    <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="#6E6E6E"/>
    <SolidColorBrush x:Key="WindowControlHoverBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="ListItemSelectedBackgroundBrush" Color="#094771"/>

    <!-- Interaction States -->
    <SolidColorBrush x:Key="ControlHoverBackgroundBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="ListItemHoverBackgroundBrush" Color="#3E3E42"/>
    <SolidColorBrush x:Key="ComboBoxHoverBackgroundBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="ControlPressedBackgroundBrush" Color="#5A5A5D"/>
    <SolidColorBrush x:Key="SecondaryButtonHoverBackgroundBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="SecondaryButtonPressedBackgroundBrush" Color="#5A5A5D"/>

    <!-- Primary Button (Accent) -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="White"/>
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#1177BB"/>
    <SolidColorBrush x:Key="ButtonPressedBackgroundBrush" Color="#094771"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="TextBoxFocusBorderBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="CheckBoxCheckmarkBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="LinkBrush" Color="#4FC3F7"/>

    <!-- Secondary Button -->
    <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#3E3E42"/>
    <SolidColorBrush x:Key="SecondaryButtonForegroundBrush" Color="#F1F1F1"/>

    <!-- Status Buttons -->
    <SolidColorBrush x:Key="DangerButtonBackgroundBrush" Color="#CD212F"/>
    <SolidColorBrush x:Key="DangerButtonHoverBackgroundBrush" Color="#E51400"/>
    <SolidColorBrush x:Key="SuccessButtonBackgroundBrush" Color="#0E7C0E"/>
    <SolidColorBrush x:Key="SuccessButtonHoverBackgroundBrush" Color="#14A814"/>

    <!-- Title Bar Extras -->
    <SolidColorBrush x:Key="TitleBarTextBrush" Color="#F1F1F1"/>
    <SolidColorBrush x:Key="CloseButtonHoverBrush" Color="#E81123"/>

    <!-- Text Brushes -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F1F1F1"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TertiaryTextBrush" Color="#B0B0B0"/>

    <!-- Tooltips -->
    <SolidColorBrush x:Key="TooltipBackgroundBrush" Color="#424245"/>
    <SolidColorBrush x:Key="TooltipTextBrush" Color="#F1F1F1"/>

    <!-- Effects -->
    <DropShadowEffect x:Key="CardShadow" ShadowDepth="2" Direction="270" BlurRadius="8" Opacity="0.3" Color="Black"/>
    <DropShadowEffect x:Key="ButtonShadow" ShadowDepth="1" Direction="270" BlurRadius="4" Opacity="0.2" Color="Black"/>

</ResourceDictionary>
