<Window x:Class="DisplayProfileManager.UI.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DisplayProfileManager.UI.Windows"
        xmlns:converters="clr-namespace:DisplayProfileManager.UI.Converters"
        mc:Ignorable="d"
        Title="Display Profile Manager" Width="900" Height="600" MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow"
        Loaded="Window_Loaded">

    <WindowChrome.WindowChrome>
        <WindowChrome 
            CaptionHeight="32"
            ResizeBorderThickness="6"
            CornerRadius="0"
            GlassFrameThickness="0,32,0,0"
            UseAeroCaptionButtons="True"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource SecondaryButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryButtonForegroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SecondaryButtonHoverBackgroundBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SecondaryButtonPressedBackgroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource DangerButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerButtonHoverBackgroundBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerButtonHoverBackgroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style x:Key="PrimaryTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="HeaderTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource PrimaryTextBlockStyle}">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource WindowControlHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlPressedBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource WindowControlHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlPressedBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource CloseButtonHoverBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource CloseButtonHoverBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <converters:ProfileIconConverter x:Key="ProfileIconConverter"/>
    </Window.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <!-- Title bar area (32px normal, 40px maximized) -->
            <RowDefinition Name="TitleBarRowDefinition" Height="32"/>
            <!-- Main content area -->
            <RowDefinition Height="*"/>
            <!-- Status bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar Area -->
        <Grid Grid.Row="0" Name="TitleBarGrid" Background="{DynamicResource TitleBarBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- App Icon and Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                <Image Name="AppIconImage" Width="16" Height="16" Margin="0,0,8,0"/>
                <TextBlock Text="Display Profile Manager"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Foreground="{DynamicResource TitleBarTextBrush}"/>
            </StackPanel>

            <!-- Window Control Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">

                <!-- Minimize Button -->
                <Button Name="MinimizeButton"
                        Content="&#xE921;"
                        Style="{StaticResource WindowControlButtonStyle}"
                        Click="MinimizeButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        ToolTip="Minimize"/>

                <!-- Maximize/Restore Button -->
                <Button Name="MaximizeRestoreButton"
                        Content="&#xE922;"
                        Style="{StaticResource WindowControlButtonStyle}"
                        Click="MaximizeRestoreButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        ToolTip="Maximize"/>

                <!-- Close Button -->
                <Button Name="CloseButton"
                        Content="&#xE8BB;"
                        Style="{StaticResource WindowCloseButtonStyle}"
                        Click="CloseButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        ToolTip="Close"/>
            </StackPanel>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="16,16,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Main Content Grid -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="342"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource ContentBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Profiles Area -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource ContentBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                Padding="16,16,16,12"
                                MinHeight="56">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Profiles"
                                               Style="{StaticResource PrimaryTextBlockStyle}"
                                               FontWeight="SemiBold"
                                               FontSize="24"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Name="DuplicateProfileButton"
                                            Content="Duplicate"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Width="Auto"
                                            Margin="0,0,8,0"
                                            Visibility="Collapsed"
                                            IsEnabled="False"
                                            Click="DuplicateProfileButton_Click"/>
                                    <Button Name="ImportButton"
                                            Content="Import"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Width="60"
                                            Margin="0,0,8,0"
                                            Click="ImportButton_Click"/>
                                    <Button Name="AddProfileButton"
                                            Content="Create"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Width="60"
                                            Click="AddProfileButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ListBox Grid.Row="1"
                                 Grid.IsSharedSizeScope="True"
                                 Name="ProfilesListBox"
                                 Style="{StaticResource PrimaryListBoxStyle}"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 VirtualizingStackPanel.ScrollUnit="Pixel"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 SelectionChanged="ProfilesListBox_SelectionChanged">

                            <ListBox.Resources>
                                <Style TargetType="{x:Type ScrollViewer}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ScrollViewer}">
                                                <Grid Background="{TemplateBinding Background}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <ScrollContentPresenter Grid.Column="0" Grid.Row="0" Margin="{TemplateBinding Padding}" />

                                                    <ScrollBar x:Name="PART_VerticalScrollBar"
                                                               Grid.Column="1"
                                                               Grid.Row="0"
                                                               Value="{TemplateBinding VerticalOffset}"
                                                               Maximum="{TemplateBinding ScrollableHeight}"
                                                               ViewportSize="{TemplateBinding ViewportHeight}"
                                                               Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>

                                                    <ScrollBar x:Name="PART_HorizontalScrollBar"
                                                               Grid.Column="0"
                                                               Grid.Row="1"
                                                               Orientation="Horizontal"
                                                               Value="{TemplateBinding HorizontalOffset}"
                                                               Maximum="{TemplateBinding ScrollableWidth}"
                                                               ViewportSize="{TemplateBinding ViewportWidth}"
                                                               Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>

                                                    <Rectangle x:Name="Corner"
                                                               Grid.Column="1"
                                                               Grid.Row="1"
                                                               Fill="{DynamicResource WindowBackgroundBrush}"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.Resources>

                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <EventSetter Event="MouseDoubleClick" Handler="ProfilesListBoxItem_MouseDoubleClick"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="ItemBorder"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4"
                                                        Padding="12,8">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SecondaryButtonHoverBackgroundBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SecondaryButtonBackgroundBrush}"/>
                                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource TertiaryTextBrush}"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsSelected" Value="True"/>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SecondaryButtonHoverBackgroundBrush}"/>
                                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource ButtonBackgroundBrush}"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Medium"
                                                           FontSize="14"
                                                           Margin="0,0,6,0"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                <Image Width="16"
                                                       Height="16"
                                                       Margin="0,2,6,0"
                                                       VerticalAlignment="Center"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Source="{Binding Icon, Converter={StaticResource ProfileIconConverter}}">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Icon}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Icon, Converter={StaticResource ProfileIconConverter}}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Default"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource ButtonBackgroundBrush}"
                                                               FontWeight="Medium"
                                                               Margin="0,2,6,0"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding IsDefault, Converter={x:Static converters:BooleanToVisibilityConverter.Instance}}"/>
                                                    <TextBlock Text="Active"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource SuccessButtonBackgroundBrush}"
                                                               FontWeight="Medium"
                                                               Margin="0,2,6,0"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding Path=DataContext.IsActive, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={x:Static converters:BooleanToVisibilityConverter.Instance}}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Description}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       LineHeight="18"
                                                       MaxHeight="54"
                                                       Margin="0,2,0,0"/>

                                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} displays">
                                                            <Binding Path="DisplaySettings.Count"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>

                                                <StackPanel Orientation="Horizontal">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HotkeyConfig.Key}" Value="{x:Static Key.None}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text=" • " FontSize="11" Foreground="{DynamicResource TertiaryTextBrush}"/>
                                                    <TextBlock Text="{Binding HotkeyConfig}" FontSize="11" FontWeight="Medium">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource TertiaryTextBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HotkeyConfig.IsEnabled}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessButtonBackgroundBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>

                                        <Button Grid.Column="1"
                                                Name="ApplyProfileButton"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="16"
                                                Width="32"
                                                Height="32"
                                                Padding="0"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Click="ApplyProfileButton_Click"
                                                ToolTip="Apply">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                    <Setter Property="Content" Value="&#xE751;"/>
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Content" Value="&#xE73E;"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Details Area -->
                <Border Grid.Column="2"
                        Background="{DynamicResource ContentBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource ContentBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                Padding="16,16,16,12"
                                MinHeight="56">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Details"
                                           Style="{StaticResource PrimaryTextBlockStyle}"
                                           FontWeight="SemiBold"
                                           FontSize="24"
                                           VerticalAlignment="Center"/>

                                <StackPanel Name="ActionButtonsPanel"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed">
                                    <Button Name="EditProfileButton"
                                            Content="Edit"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Width="60"
                                            Margin="0,0,8,0"
                                            IsEnabled="False"
                                            Click="EditProfileButton_Click"/>
                                    <Button Name="DeleteProfileButton"
                                            Content="Delete"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Width="60"
                                            IsEnabled="False"
                                            Click="DeleteProfileButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" Padding="16,8,16,16" VerticalScrollBarVisibility="Auto">
                            <StackPanel Name="ProfileDetailsPanel">
                                <TextBlock Text="Select a profile to view details"
                                           Style="{StaticResource PrimaryTextBlockStyle}"
                                           Foreground="{DynamicResource TertiaryTextBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Margin="0,32"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource WindowBackgroundBrush}"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Name="RefreshButton"
                            FontFamily="Segoe MDL2 Assets"
                            Content="&#xE72C;"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="32"
                            Height="32"
                            Padding="0"
                            Margin="0,0,8,0"
                            ToolTip="Refresh Profiles and Themes"
                            Click="RefreshButton_Click"/>

                    <TextBlock Name="StatusTextBlock"
                               Text="Ready"
                               Style="{StaticResource PrimaryTextBlockStyle}"
                               FontSize="12"
                               Foreground="{DynamicResource TertiaryTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Name="OpenDataFolderButton"
                        Content="Open Folder"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0"
                        Click="OpenDataFolderButton_Click"/>
                <Button Grid.Column="2"
                        Name="SettingsButton"
                        Content="Settings"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="SettingsButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>